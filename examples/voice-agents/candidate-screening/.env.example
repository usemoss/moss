# LiveKit (only needed for `agent.py dev` - leave blank for `agent.py console`).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Moss (sign up free at https://moss.dev)
MOSS_PROJECT_ID=your-moss-project-id
MOSS_PROJECT_KEY=your-moss-project-key

# Index names. create_indexes.py picks these defaults from the fixture data;
# override only if you want a custom naming scheme.
# MOSS_JOB_INDEX_NAME=job-senior-backend-payments
# MOSS_CANDIDATE_INDEX_NAME=candidate-strong-match

# Voice pipeline providers
OPENAI_API_KEY=your-openai-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
CARTESIA_API_KEY=your-cartesia-api-key

# Where to write scorecards (default: ./scorecards). Created on demand.
# SCREENING_SCORECARD_DIR=./scorecards
