# LiveKit (only needed for `agent.py dev` - leave blank for `agent.py console`).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Moss (sign up free at https://moss.dev)
MOSS_PROJECT_ID=your-moss-project-id
MOSS_PROJECT_KEY=your-moss-project-key

# Optional: an IVR could pre-capture the PNR and pass it via this env var
# so the agent's index is warm before the caller says a word. If unset,
# the agent asks for the PNR conversationally.
# BOOKING_PNR=WJ7BNH

# Voice pipeline providers
OPENAI_API_KEY=your-openai-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
CARTESIA_API_KEY=your-cartesia-api-key

# Where to write call summaries (default: ./call-summaries). Created on demand.
# AIRLINE_CALL_SUMMARY_DIR=./call-summaries
