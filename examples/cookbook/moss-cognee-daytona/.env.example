# Daytona — https://app.daytona.io -> API keys
DAYTONA_API_KEY=

# Anthropic — https://console.anthropic.com -> API keys
ANTHROPIC_API_KEY=

# LLM for Cognee graph extraction (default provider: openai)
LLM_API_KEY=


# Moss — https://moss.dev -> project settings
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=

# Optional: override the repo the agents will explore
# TARGET_REPO=https://github.com/topoteretes/cognee

# Optional: override the Daytona API endpoint
# DAYTONA_API_URL=https://app.daytona.io/api
