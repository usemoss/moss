# Benchmark credentials. Copy to .env in this directory.
# MOSS_PROJECT_ID / MOSS_PROJECT_KEY come from the repo-root .env.example.

# Moss index used by bench_moss.py and corpus.py
MOSS_INDEX_NAME=benchmark-public

# Pinecone (bench_pinecone.py)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Qdrant Cloud (bench_qdrant.py)
QDRANT_URL=your_qdrant_cloud_url
QDRANT_API_KEY=your_qdrant_api_key

# Embedding backend (embedding.py)
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your_openai_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Optional: custom embedding HTTP endpoint
# EMBEDDING_ENDPOINT=https://your-embedding-host/embed
# EMBEDDING_MAX_BATCH_SIZE=32
