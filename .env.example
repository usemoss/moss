# Moss credentials are the only thing every example/app needs.
# Get yours at https://moss.dev - free tier available.
#
# Per-feature credentials (LiveKit, Qdrant, OpenAI, Pinecone, ...) live in
# the .env.example of the specific subdirectory that needs them. Copy this
# file PLUS the subdirectory's .env.example into your local .env.

MOSS_PROJECT_ID=your_project_id_here
MOSS_PROJECT_KEY=your_project_key_here
