# --- Moss (retrieval) ---
MOSS_PROJECT_ID=your_moss_project_id
MOSS_PROJECT_KEY=your_moss_project_key
MOSS_INDEX_NAME=moss-voice-demo
MOSS_TOP_K=5
MOSS_ALPHA=0.8

# --- Deepgram (speech-to-text) ---
DEEPGRAM_API_KEY=your_deepgram_api_key

# --- OpenAI (LLM) ---
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# --- ElevenLabs (text-to-speech) ---
ELEVENLABS_TTS_KEY=your_elevenlabs_key
# Optional: pick a voice (default is a standard ElevenLabs voice)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- Speed showcase ---
# 0 = real Moss (in-process, ~2 ms/turn).
# Set to e.g. 400 to simulate a remote vector-DB round trip and hear the agent lag.
SIMULATE_REMOTE_MS=0
