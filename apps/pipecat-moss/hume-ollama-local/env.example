# Ollama (optional, defaults shown)
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://ollama:11434/v1

# Daily WebRTC (only needed if running with -t daily)
# DAILY_API_KEY=your_daily_api_key
