# Moss — portal.usemoss.dev
MOSS_PROJECT_ID=your_moss_project_id
MOSS_PROJECT_KEY=your_moss_project_key
MOSS_INDEX_NAME=your_moss_index_name

# ElevenLabs — get API key at elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ElevenLabs Conversational AI Agent ID
# Create an agent at elevenlabs.io and add a client tool named
# "search_knowledge_base" with a "query" string parameter.
# Enable "Wait for response" on the tool.
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
