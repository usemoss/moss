{
  "name": "vitepress-plugin-moss",
  "version": "1.0.0-beta.2",
  "description": "Moss semantic search plugin for VitePress",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./Search.vue": "./Search.vue",
    "./types": "./types.ts"
  },
  "files": [
    "dist",
    "Search.vue",
    "SearchButton.vue",
    "types.ts",
    "MossLogo_Dark_Icon.png"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "documentation:build": "pnpm build && cd demo-site && pnpm install && vitepress build documentation",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "vitepress": ">=1.0.0"
  },
  "dependencies": {
    "@moss-dev/moss-web": "^1.0.0",
    "@moss-tools/md-indexer": "^1.0.0-beta.3",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "focus-trap": "^8.0.1",
    "obug": "^1.0.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^5.0.0",
    "vitepress": "^1.5.0",
    "vitest": "^3.1.1",
    "vue": "^3.5.0",
    "@vue/language-core": "^3.2.7"
  },
  "keywords": [
    "vitepress",
    "plugin",
    "moss",
    "search",
    "semantic-search"
  ],
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "docs"
  },
  "overrides": {
    "@vue/language-core": "^3.2.7",
    "lodash": "^4.18.1",
    "minimatch@>=9.0.0 <9.0.7": "9.0.9",
    "minimatch@<3.1.3": "3.1.5",
    "postcss": "^8.5.13",
    "esbuild": "^0.25.12",
    "vite": "^6.4.3",
    "undici": "^7.28.0",
    "protobufjs": "^8.7.1",
    "gray-matter": "npm:@gr2m/gray-matter@4.0.3-with-pr-137"
  }
}
