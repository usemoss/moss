{
  "name": "@moss-tools/vercel-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK tools for MOSS semantic search",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai-sdk",
    "vercel-ai",
    "moss",
    "semantic-search",
    "inferedge"
