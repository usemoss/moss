{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (open this folder as workspace)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: watch",
      "env": {
        "MOSS_PROJECT_ID": "",
        "MOSS_PROJECT_KEY": ""
      }
    }
  ]
}
