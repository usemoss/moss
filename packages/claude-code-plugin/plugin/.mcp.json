{
  "mcpServers": {
    "moss-search": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-launcher.cjs"],
      "env": {
        "MOSS_PROJECT_ID": "${MOSS_PROJECT_ID}",
        "MOSS_PROJECT_KEY": "${MOSS_PROJECT_KEY}",
        "MOSS_INDEX_NAME": "${MOSS_INDEX_NAME}",
        "NODE_PATH": "${CLAUDE_PLUGIN_ROOT}/../node_modules"
      }
    }
  }
}
