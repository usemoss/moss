{
  "name": "@moss-tools/mastra",
  "version": "0.1.0",
  "description": "Moss semantic search tools for Mastra agents",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "mastra",
    "moss",
    "semantic-search",
    "rag",
    "ai-agent",
    "inferedge"
  ],
  "author": "InferEdge Inc.",
  "license": "BSD-2-Clause",
  "peerDependencies": {
    "@mastra/core": ">=1.0.0",
    "@moss-dev/moss": "^1.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "devDependencies": {
    "@mastra/core": "1.26.0",
    "@moss-dev/moss": "1.0.0",
    "@types/node": "22.13.14",
    "tsup": "8.4.0",
    "typescript": "5.8.2",
    "vitest": "3.2.6",
    "zod": "3.25.76"
  }
}
