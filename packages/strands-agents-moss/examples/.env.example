# Moss credentials — get them from https://portal.usemoss.dev
MOSS_PROJECT_ID=your-project-id
MOSS_PROJECT_KEY=your-project-key
MOSS_INDEX_NAME=my-index

# Strands Agents defaults to Amazon Bedrock as the model provider.
# If using Bedrock, ensure your AWS credentials are configured:
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
#   AWS_REGION=us-east-1
#
# To use OpenAI instead, set:
#   OPENAI_API_KEY=your-openai-key
# and pass model=OpenAIModel("gpt-4o") to Agent().
