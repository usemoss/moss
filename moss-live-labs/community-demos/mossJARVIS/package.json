{
  "name": "jarvis-second-brain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "desktop": "tauri dev",
    "prepare:desktop": "next build && mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/ && cp -R public .next/standalone/ && node scripts/prepare-desktop.mjs",
