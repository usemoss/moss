{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarvis",
  "version": "0.1.0",
  "identifier": "ai.jarvis.secondbrain",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "pnpm prepare:desktop",
    "frontendDist": "../desktop-shell"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [],
    "resources": {
      "../.desktop-server/": "server/",
      "resources/node": "runtime/node"
    }
  }
}
