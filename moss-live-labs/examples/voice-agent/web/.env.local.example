LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional: allow token minting for non-loopback clients.
# `npm run dev:lan` sets this automatically — you do not need TRUST_PROXY for LAN access.
# ALLOW_REMOTE_TOKEN=1

# Reverse-proxy mode (optional). Origin must not be publicly reachable.
# TRUSTED_PROXIES is required when TRUST_PROXY=1 — only those immediate peers may
# supply forwarded client IPs. Use "loopback" and/or concrete proxy addresses.
#   TRUST_PROXY=1
#   TRUSTED_PROXIES=loopback,10.0.0.2
#   TRUST_PROXY_HEADER=x-forwarded-for   # default; or x-real-ip (overwrite strategy)
#   TRUSTED_PROXY_HOPS=1
