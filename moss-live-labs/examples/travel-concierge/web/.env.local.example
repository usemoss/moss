LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional server-only access code. When set, visitors unlock once via /api/gate
# (httpOnly cookie) before /api/token mints a LiveKit JWT. Never expose this as
# NEXT_PUBLIC_* — a client-bundled secret cannot protect the endpoint.
# Leave unset for open local demos; set before any public deploy.
# APP_SECRET=

# Optional: exactly one trusted client-IP header for per-IP rate-limit buckets.
# Must match a header your edge/proxy sets itself (not client-spoofable):
#   cf-connecting-ip       — Cloudflare
#   x-vercel-forwarded-for — Vercel
#   x-real-ip              — nginx/other only if the proxy replaces it with the verified peer
# Leave unset to use a shared global bucket. Never set this to x-forwarded-for.
# TRUSTED_CLIENT_IP_HEADER=cf-connecting-ip
