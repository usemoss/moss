{
  "name": "@moss-dev/moss",
  "version": "1.0.0",
  "main": "dist/index.esm.js",
  "module": "dist/index.esm.js",
  "types": "dist/moss.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/moss.d.ts",
      "node": "./dist/index.esm.js",
      "default": "./dist/index.esm.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist temp .log",
    "build": "npm run build:types && npm run build:js && api-extractor run --local",
    "build:types": "tsc --emitDeclarationOnly",
    "build:js": "tsx esbuild.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts test/**/*.ts",
    "run-query-sample": "tsx samples/query.ts",
    "run-multi-index": "tsx samples/multiple-indexes.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "extract-api": "npm run build && api-extractor run --local",
    "prepack": "npm run clean && npm run build",
    "docs": "typedoc --options typedoc.json && mkdir -p ../../documentation/docs/reference/js/_media && cp LICENSE ../../documentation/docs/reference/js/_media/LICENSE"
  },
  "files": [
    "dist/index.esm.js",
    "dist/moss.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "search",
    "semantic",
    "embeddings",
    "vector",
    "usemoss",
    "moss"
  ],
  "author": "InferEdge Inc. <contact@moss.dev>",
  "license": "BSD-2-Clause",
  "dependencies": {
    "@moss-dev/moss-core": "^0.8.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@microsoft/api-extractor": "^7.58.1",
    "@types/javascript-obfuscator": "^0.0.5",
    "@types/node": "^22.18.3",
    "dotenv": "^17.2.1",
    "esbuild": "^0.27.4",
    "esbuild-plugin-obfuscator": "^1.2.4",
    "rimraf": "^6.0.1",
    "eslint": "^8.57.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^4.1.3"
  }
}
