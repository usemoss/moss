# Copy to .env and fill in your Moss project credentials (from https://moss.dev).
MOSS_PROJECT_ID=your-project-id
MOSS_PROJECT_KEY=your-project-key

# Location of the native libmoss runtime (download from the c-sdk release).
# Point this at the directory containing libmoss.dylib / libmoss.so.
MOSS_LIB_DIR=/path/to/libmoss/lib
